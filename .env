# Database Configuration (PostgreSQL local server)
DATABASE_URL=postgresql://postgres:postgrePassword@localhost:5432/placement_prep

# Redis Configuration (change to localhost if running outside docker)
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
OPENAI_API_KEY="YourOpenAPIKey"
LLM_MODEL=gpt-4o-mini

# JWT Configuration 
JWT_SECRET_KEY=JWTSPECIALKEY!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File Upload Configuration
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# Loop Engineering Thresholds
LOOP_RESUME_THRESHOLD=85
LOOP_INTERVIEW_THRESHOLD=85
