# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/placement_prep

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
# Base URL for local/alternative models (e.g. Ollama)
# LLM_BASE_URL=http://localhost:11434/v1

# JWT Configuration
JWT_SECRET_KEY=supersecretjwtkeychangeinproduction123456!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File Upload Configuration
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# Loop Engineering Thresholds
LOOP_RESUME_THRESHOLD=85
LOOP_INTERVIEW_THRESHOLD=85

# MCP Server Mappings (if running external MCP servers)
# MCP_PDF_SERVER_URL=http://localhost:5001
# MCP_GITHUB_SERVER_URL=http://localhost:5002
# MCP_SEARCH_SERVER_URL=http://localhost:5003
# MCP_FS_SERVER_URL=http://localhost:5004
